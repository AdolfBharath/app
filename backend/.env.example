# Rename this file to .env and update values

DATABASE_URL=postgresql://username:password@localhost:5432/jenovate
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — server will refuse to start if not set
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── Super-Admin Seeding ───────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@jenovate.com
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_USERNAME=admin.super
SUPER_ADMIN_NO=ADM-2024-X99

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. Mobile apps (no Origin
# header) and local dev are always allowed even without this setting.
# Example: ALLOWED_ORIGINS=https://admin.jenovate.com,https://app.jenovate.com
# ALLOWED_ORIGINS=

# ── Welcome Email (admin creates user) ───────────────────────────────────────
# Configure SMTP credentials via environment variables (no hardcoded secrets).
# Either use SMTP_SERVICE (e.g., gmail) OR SMTP_HOST/SMTP_PORT.
SMTP_SERVICE=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=Jenovate LMS <your_email@gmail.com>

# Login URL included in welcome emails.
LMS_LOGIN_URL=http://localhost:3000/login

# ── Google Drive Upload (student task submissions) ───────────────────────────
# Folder where uploaded student files will be stored.
GOOGLE_DRIVE_FOLDER_ID=1H33QJ1tIPxyx7WLVj1hyvgFYDdjXI-Sd

# Use ONE of the credential options below:
# 1) Raw JSON (single-line JSON string)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# 2) Base64-encoded JSON key
# GOOGLE_SERVICE_ACCOUNT_BASE64=
#
# 3) Path to service account JSON key file on server
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
#
# 4) Split env vars
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
